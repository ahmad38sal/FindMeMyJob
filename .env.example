# ── LLM provider ────────────────────────────────────────────────────────────
# Provider: openai (default) | anthropic | gemini
LLM_PROVIDER=openai

# API keys — only the one matching your provider is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Model overrides (optional — defaults to provider-appropriate model)
LLM_MODEL=
LLM_MATCH_MODEL=
LLM_TAILOR_MODEL=

# ── Database ─────────────────────────────────────────────────────────────────
# Railway Postgres — Railway sets this automatically when you add a Postgres plugin.
# Leave blank to use local SQLite (./data/findmemyjob.db).
DATABASE_URL=

# ── Storage ──────────────────────────────────────────────────────────────────
# Path for DB, generated resumes, and apple_session.json.
# On Railway: mount a Volume at /data and set DATA_DIR=/data
DATA_DIR=./data

# ── Chrome extension API ──────────────────────────────────────────────────────
# Set a random secret to enable /api/ext/* routes used by the browser extension.
# Leave blank to disable.
FINDMEMYJOB_EXT_TOKEN=

# ── Apple internal careers ────────────────────────────────────────────────────
# Custom Apple internal careers search URL (optional — can also set via the UI).
APPLE_INTERNAL_CAREERS_URL=
